# =====================================================
# HHG-SPA POS — Environment Template
# 複製為 .env.local 並填入實際值
# =====================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# Supabase CLI / Management
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD
SUPABASE_ACCESS_TOKEN=sbp_xxx

# --- Acumatica ERP ---
ACUMATICA_BASE_URL=https://your-instance.acumatica.com
ACUMATICA_COMPANY=YourCompany
ACUMATICA_BRANCH=OSP2
ACUMATICA_LEDGER_ID=MGMT
ACUMATICA_API_VERSION=23.200.001
ACUMATICA_SERVICE_USERNAME=service_account
ACUMATICA_SERVICE_PASSWORD=service_password

# --- Session ---
# 隨機 32+ 字元字串
SESSION_SECRET=please-generate-a-strong-random-32-char-min-secret

# --- App Config ---
NEXT_PUBLIC_APP_NAME=HHG-SPA POS
NEXT_PUBLIC_APP_VERSION=0.1.0
